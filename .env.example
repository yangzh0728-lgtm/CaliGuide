# API_KEY and APP_ID: Required for CaliBot chat responses through the
# OpenAI-compatible Qianfan endpoint used by deepseek.py.
API_KEY="MY_API_KEY"
APP_ID="MY_APP_ID"

# CHAT_MODEL: Optional. Leave blank to use the server default.
# Example: CHAT_MODEL="deepseek-v4-flash"
CHAT_MODEL="deepseek-v4-flash"

# CHAT_VISION_MODEL: Optional but required for chatbot image reading when
# CHAT_MODEL is text-only. Set this to a vision-capable model available on
# your OpenAI-compatible provider.
# Example: CHAT_VISION_MODEL="qwen-vl-plus"
CHAT_VISION_MODEL="qwen-vl-plus"

# MEM0_API_KEY: Optional but recommended. Enables user-level long-term
# memory for CaliBot through mem0. Without it, chat still works but has no
# cross-session user memory.
MEM0_API_KEY="MY_MEM0_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: Optional. Set this in static frontend deployments when
# the Express API runs on a separate backend origin.
# Example: VITE_API_BASE_URL="https://api.caliguide.org"
VITE_API_BASE_URL=""

# CORS_ALLOWED_ORIGINS: Optional comma-separated frontend origins allowed to
# call the Express API when API and frontend are on different domains.
CORS_ALLOWED_ORIGINS="https://www.caliguide.org,https://caliguide.org"

# Supabase browser/public config.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_or_anon_key"

# Supabase server-only key. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY="sb_secret_or_service_role_key"

# Cloudflare R2 server-only upload config.
CLOUDFLARE_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="caliguide-media"
R2_PUBLIC_BASE_URL="https://media.example.com"

# Optional IDs used by bun run seed:r2-structure to create visible JSON placeholders in R2.
R2_MOCK_USER_ID="user-demo-1"
R2_MOCK_POST_ID="post-demo-1"
R2_MOCK_GUIDE_ID="guide-dmv-checklist"
