# API_KEY and APP_ID: Required for CaliBot chat responses through the
# OpenAI-compatible Qianfan endpoint used by deepseek.py.
API_KEY="MY_API_KEY"
APP_ID="MY_APP_ID"

# CHAT_MODEL: Optional. Leave blank to use the server default.
# Example: CHAT_MODEL="deepseek-v4-flash"
CHAT_MODEL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
